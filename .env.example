# Public site URL (used for Open Graph / social preview metadata)
NEXT_PUBLIC_SITE_URL=https://closernet.net

# xAI — https://console.x.ai (CloserValue AI via Grok)
XAI_API_KEY=
XAI_MODEL=grok-3-latest

# Resend — https://resend.com (enables confirmation emails)
RESEND_API_KEY=
RESEND_FROM_EMAIL=CloserNet <support@closernet.net>
# Where YOU get alerted for new signups — use a personal Gmail you actually check
# unless support@closernet.net has a GoDaddy mailbox or forwarding set up
WAITLIST_NOTIFY_EMAIL=your.email@gmail.com