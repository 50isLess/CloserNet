# Public site URL (used for Open Graph / social preview metadata)
NEXT_PUBLIC_SITE_URL=https://closernet.vercel.app

# xAI — https://console.x.ai (CloserValue AI via Grok)
# grok-3-mini is cheapest (~$0.0003/estimate). Fallback: grok-4.3 with reasoning_effort none
XAI_API_KEY=
XAI_MODEL=grok-3-mini

# Resend — https://resend.com (enables confirmation emails)
RESEND_API_KEY=
RESEND_FROM_EMAIL=CloserNet <onboarding@resend.dev>
WAITLIST_NOTIFY_EMAIL=support@closernet.net